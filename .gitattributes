# Normalização de fim de linha (recomendado em equipas mistas Windows/macOS/Linux)
* text=auto

# Código e shaders — texto, LF
*.cs text eol=lf diff=csharp
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.compute text eol=lf
*.glsl text eol=lf
*.shadergraph text eol=lf
*.shadersubgraph text eol=lf

# Texto / config
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.asmdef text eol=lf
*.rsp text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.config text eol=lf
*.manifest text eol=lf
*.csv text eol=lf

# YAML do Unity — merge=union reduz conflitos em cenas/prefabs (não substitui revisão humana)
*.meta merge=union linguist-language=YAML
*.unity merge=union linguist-language=YAML
*.prefab merge=union linguist-language=YAML
*.asset merge=union linguist-language=YAML
